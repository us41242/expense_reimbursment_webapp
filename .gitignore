# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/build

# misc
.DS_Store
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# IDE / Editor
.idea
.vscode
.cursor
*.swp

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
